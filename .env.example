# Channel Patterns Analyzer — environment template
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit your real values.

# ─── Data source mode ───────────────────────────────────────────
# `bigquery` (default) — analyzer queries BigQuery via the bq CLI
# `csv`               — analyzer reads from ./sample_data/*.csv (CSV fallback)
DATA_SOURCE=bigquery

# ─── Google Cloud / BigQuery ────────────────────────────────────
# Project that holds the youtube_analytics dataset.
# The bq CLI reads this from your active gcloud config OR from this env var
# if you prefer to override per-project. Set with: gcloud config set project <id>
BQ_PROJECT=your-gcp-project-id

# Dataset name (default matches the youtube-bigquery-pipeline default).
# Change here if your pipeline lands data in a differently-named dataset; the
# analyzer should template SQL with this value when it builds.
BQ_DATASET=youtube_analytics

# ─── YouTube channel identity ───────────────────────────────────
# Your channel ID (UC-prefixed). Used for filtering when needed.
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx

# ─── Notion ──────────────────────────────────────────────────────
# The Notion page (or database) where the analyzer writes the weekly report.
# Get this from the page URL: notion.so/<workspace>/<page-id> — use the page-id portion.
NOTION_REPORT_PAGE_ID=

# ─── Analysis configuration ─────────────────────────────────────
# Look-back window for the weekly analysis (in days)
ANALYSIS_LOOKBACK_DAYS=90

# Minimum video age (days) before a video counts toward pattern analysis
MIN_VIDEO_AGE_DAYS=14

# Timezone for "Monday at 9am" scheduling and CURRENT_DATE() comparisons.
# Defaults to America/Phoenix (the youtube-bigquery-pipeline scheduler runs here).
SCHEDULE_TIMEZONE=America/Phoenix
